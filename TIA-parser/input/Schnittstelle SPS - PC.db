DATA_BLOCK "Schnittstelle SPS - PC"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
NON_RETAIN
   VAR 
      "SPS -> PC" { ExternalWritable := 'False'} : Struct
         "SPS an" { ExternalWritable := 'False'} : Bool;   // SPS ist eingeschaltet und hochgefahren
         "Einschaltschütze an" { ExternalWritable := 'False'} : Bool;   // SPS ist hochgefahren und Einschaltschütze sind an
         "N-H 1 =A1+01-30S4 quitt" { ExternalWritable := 'False'} : Bool;   // Not-Halt  Anlage intern =A1+01-30S4 quittiert
         "N-H 2 =A1+01-30S5 quitt" { ExternalWritable := 'False'} : Bool;   // Not-Halt  Ecke außerhalb =A1+01-30S5 quittiert
         "N-H 3 =A2+02-30S2 quitt" { ExternalWritable := 'False'} : Bool;   // Not-Halt Panelgehäuse =A2+02-30S2 quittiert
         "N-H 4 =A3+03-30S4 quitt" { ExternalWritable := 'False'} : Bool;   // Not-Halt Eingabemodul =A3+03-30S4 quittiert
         "N-H 1-4 quitt" { ExternalWritable := 'False'} : Bool;   // Not-Halt 1-4 quittiert
         "ST 1 =A3+03-30S2 verr" { ExternalWritable := 'False'} : Bool;   // Schutztür  Modul 1000 =A3+03-30S2 verriegelt
         "ST 2 =A3+03-30S1 verr" { ExternalWritable := 'False'} : Bool;   // Schutztür Modul 200 =A3+03-30S1 verriegelt
