         "Bus nio Switch A2_02_1" { ExternalWritable := 'False'} : Bool;   // Profinetteilnehmer 192.168.0.22 nicht erreichbar
         "Bus nio Switch A2_02_2" { ExternalWritable := 'False'} : Bool;   // Profinetteilnehmer 192.168.0.23 nicht erreichbar
