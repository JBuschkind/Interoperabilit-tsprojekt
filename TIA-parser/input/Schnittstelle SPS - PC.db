         "ST 1-6 verr" { ExternalWritable := 'False'} : Bool;   // Schutztüren 1-6 verriegelt
         "ST 7 =A3+03-31S5 geschl" { ExternalWritable := 'False'} : Bool;   // Schutztür Modul 100 Eingabe =A3+03-31S5 geschlossen
         "Bus nio Festo Contr M400" { ExternalWritable := 'False'} : Bool;   // Profinetteilnehmer 192.168.0.30 nicht erreichbar
